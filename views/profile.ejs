<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="../public/image/steam_color.svg">
    <title>Valvole</title>
    <link rel="stylesheet" type="text/css" href="../public/css/profile.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>

<div id="navbar" >
    <!-- inniezione Navbar -->
</div>

<!-- Main Content -->
<main >

    <div id="profile-container">
        <span id="image-container">
            <img id="image-profile">
        </span>
        <h1 id="username"></h1>
        <p id="mail"> </p>

        <h3 id="name"></h3>
        <h3 id="lastname"></h3>
        <h3 id="password">Password: *********</h3>
        <a href="#" id="edit-button" class="btn btn-primary">Cange-Attribute</a>


    </div>

    <!-- Modulo di modifica -->
    <form id="profile-edit-form" action="/profile/update" method="POST" enctype="multipart/form-data">
        <div class="mb-3">
            <label for="profileImage" class="form-label">Image Profile</label>
            <input type="file" class="form-control" id="profileImage" name="profileImage" accept="image/*">
        </div>
        <div class="mb-3">
            <label for="firstname" class="form-label">Name</label>
            <input type="text" class="form-control" id="firstname" name="firstname" placeholder="Insert new Name >
        </div>
        <div class="mb-3">
            <label for="lastname" class="form-label">Lastname</label>
            <input type="text" class="form-control" id="lastname" name="lastname" placeholder="Insert new Lastname" >

        </div>
        <div class="mb-3">
            <label for="mail" class="form-label">Email</label>
            <input type="email" class="form-control" id="mail" name="mail" placeholder="Insert new Email">
        </div>

        <div class="mb-3">
            <label for="password" class="form-label">New Password</label>
            <input type="password" class="form-control" id="password" name="password" placeholder="Insert new password" >
        </div>
        <button type="submit" id="save" class="btn btn-success">Confirm</button>
    </form>




</main>

<!-- Bootstrap Script -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.2/dist/umd/popper.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
<script type="module" src="../public/js/template/navbar-loader.js"></script>
<script type="module" src="../public/js/template/navbar-function.js"></script>
<script type="module" src="../public/js/profile-loader.js"></script>









</body>
</html>
