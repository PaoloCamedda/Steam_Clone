<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="../public/image/steam_color.svg">
    <title>Valvole</title>
    <link rel="stylesheet" type="text/css" href="../public/css/index.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>

<div id="navbar" >
    <!-- inniezione Navbar -->
</div>

<!-- Main Content -->
<main class="container mt-4">
    <div class="row">

        <!-- Colonna Destra: Slot per i Giochi -->
        <div class="col-md-9">
            <div id="games-container" class="row">
                <table id="games-table" class="table">
                    <thead>
                    <tr>
                        <th scope="col">image</th>
                        <th scope="col">name</th>
                        <th scope="col">relese</th>
                        <th scope="col">category</th>
                        <th scope="col">prezzo</th>
                    </tr>
                    </thead>
                    <tbody>
                    <tr>
                        <th scope="col">
                            <img  id='imgSnake' src="../public/image/snake.png">
                        </th>
                        <th scope="col">Snake</th>
                        <th scope="col">1997</th>
                        <th scope="col">casual</th>
                        <th scope="col">
                            <button id="playSnake" onclick="window.location.href='../public/snake.html';">Play Demo Now</button>
                        </th>
                    </tr>
                    <!-- Giochi verranno aggiunti qui -->
                    </tbody>

                    <!-- I giochi saranno inseriti qui dinamicamente con JavaScript -->
                </table>


            </div>
        </div>
        <!-- Colonna Sinistra: Barra di Ricerca e Categorie -->
        <div class="col-md-3">
            <form class="d-flex mb-4" role="search">
                <input id="search-input" class="form-control me-2" type="search" placeholder="Search" aria-label="Search">
                <button class="btn btn-outline-success" type="submit">
                    <img src="./svg/search.svg" width="20" height="20">
                </button>
            </form>

            <!-- Categorie di Filtri -->
            <ul class="list-group" href="/">
                <li class="list-group-item" data-filter="All" href="/">All</li>

                <li class="list-group-item" data-filter="under-5" href="/">Under 5€</li>
                <li class="list-group-item" data-filter="under-10" href="/">Under 10€</li>

                <div class="dropdown">
                    <a class="list-group-item dropdown-toggle" data-filter="All" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown" aria-expanded="false">
                        Categorie
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuLink" data-filter="cat" id="categoryDropdown">

                        <!-- Aggiungi altre categorie come necessario -->
                    </ul>
                </div>

            </ul>
        </div>


    </div>
</main>

<!-- Bootstrap Script -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.2/dist/umd/popper.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>




</body>
</html>
