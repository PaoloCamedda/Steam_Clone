<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="../public/image/steam_color.svg">
    <title>Valvole</title>
    <link rel="stylesheet" type="text/css" href="../public/css/index.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>

<div id="navbar" >
    <!-- inniezione Navbar -->
</div>

<!-- Main Content -->
<main class="container mt-4">
    <div class="row">

        <!-- Colonna Sinista: Slot per i Giochi -->
        <div class="col-md-9">
            <div id="games-container" class="row">
                <table id="games-table" class="table">
                    <thead>
                    <h1> GAMES</h1>
                    </thead>
                    <tbody>

                    <!-- Giochi verranno aggiunti qui -->


                    </tbody>


                </table>


            </div>


        </div>
        <!-- Colonna Destra: Barra di Ricerca e Categorie -->
        <div class="col-md-3">
            <div class="search-section">
                <form class="d-flex mb-4" role="search">
                    <input id="search-input" class="form-control me-2" type="search" placeholder="Search" aria-label="Search">
                    <button class="btn btn-primary" type="submit">
                        <img src="../public/image/search.svg" width="20" height="20">
                    </button>
                </form>
            </div>


            <!-- Categorie di Filtri -->
            <ul class="list-group" href="/">
                <li class="list-group-item" data-filter="All" href="/">All</li>

                <li class="list-group-item" data-filter="under-5" href="/">Under 5€</li>
                <li class="list-group-item" data-filter="under-10" href="/">Under 10€</li>

                <div class="dropdown">
                    <a class="list-group-item dropdown-toggle" data-filter="All" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown" aria-expanded="false">
                        Category
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuLink" data-filter="cat" id="categoryDropdown">

                        <!-- Aggiungi altre categorie come necessario -->
                    </ul>
                </div>
                <div id="game-card" class="mt-4">
                    <!-- Snake verrà aggiunto qui -->
                </div>

            </ul>
        </div>


    </div>
</main>

<!-- Bootstrap Script -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.2/dist/umd/popper.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
<script type="module" src="../public/js/template/navbar-loader.js"></script>
<script type="module" src="../public/js/template/navbar-function.js"></script>
<script type="module" src="../public/js/games-loader.js"></script>
<script type="module" src="../public/js/category.js"></script>
<script type="module" src="../public/js/search.js"></script>
<script type="module" src="../public/js/filters.js"></script>







</body>
</html>